.hero {
  width: 100%; height: 480rpx; display: flex; align-items: center;
  justify-content: center; overflow: hidden;
}
.hero-img { width: 100%; height: 100%; padding: 32rpx; }

.name { font-size: 40rpx; font-weight: 800; }
.tags-row { display: flex; gap: 12rpx; justify-content: center; margin-top: 12rpx; }
.meta-row { display: flex; gap: 40rpx; justify-content: center; margin-top: 20rpx; }
.meta-item { text-align: center; }
.meta-lbl { font-size: 20rpx; color: var(--text-secondary); }
.meta-val { font-size: 28rpx; margin-top: 4rpx; display: block; }
.stars { color: #FF9800; }
.diff { color: #E53935; }

.body-text { font-size: 26rpx; color: #555; line-height: 1.8; }
.peak-row { display: flex; gap: 8rpx; margin-top: 16rpx; flex-wrap: wrap; }
.record-text { font-size: 24rpx; color: var(--text-secondary); margin-top: 12rpx; display: block; }

.bait-row { display: flex; gap: 12rpx; flex-wrap: wrap; }

.tips-box {
  margin-top: 16rpx; padding: 20rpx; background: #E8F8EF;
  border-radius: var(--radius-sm); font-size: 24rpx; color: #10703D; line-height: 1.6;
}

.catch-photo { width: 100%; max-height: 480rpx; border-radius: var(--radius-sm); margin-bottom: 12rpx; background: #f5f5f5; }
.catch-info { font-size: 24rpx; color: #555; text-align: center; margin-bottom: 12rpx; }
.catch-upload-preview { width: 100%; height: 280rpx; border-radius: var(--radius-sm); }
.photo-upload { margin-bottom: 12rpx; }
.photo-placeholder-small {
  border: 2rpx dashed #D0D5DD; border-radius: var(--radius-sm);
  padding: 48rpx; text-align: center; display: flex;
  flex-direction: column; align-items: center; gap: 8rpx;
}
.form-input {
  width: 100%; padding: 18rpx 0; border-bottom: 1px solid #f0f0f0;
  font-size: 28rpx; margin-bottom: 4rpx;
}
.pick-spot { color: #1AAD5F; }
.pub-btn {
  background: linear-gradient(135deg, #1AAD5F, #2BD472); color: #fff;
  margin-top: 20rpx; border-radius: var(--radius-sm);
  font-size: 30rpx; font-weight: 700;
}
.btn-small {
  padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 24rpx;
  margin: 0 auto; display: block;
}
.btn-danger { background: #FA5151; color: #fff; }
