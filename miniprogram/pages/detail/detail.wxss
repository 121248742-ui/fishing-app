.hero {
  width: 100%; height: 480rpx; display: flex; align-items: center;
  justify-content: center; overflow: hidden;
}
.hero-img { width: 100%; height: 100%; padding: 32rpx; }

.name { font-size: 40rpx; font-weight: 800; }
.tags-row { display: flex; gap: 12rpx; justify-content: center; margin-top: 12rpx; }
.meta-row { display: flex; gap: 40rpx; justify-content: center; margin-top: 20rpx; }
.meta-item { text-align: center; }
.meta-lbl { font-size: 20rpx; color: var(--text-secondary); }
.meta-val { font-size: 28rpx; margin-top: 4rpx; display: block; }
.stars { color: #FF9800; }
.diff { color: #E53935; }

.body-text { font-size: 26rpx; color: #555; line-height: 1.8; }
.peak-row { display: flex; gap: 8rpx; margin-top: 16rpx; flex-wrap: wrap; }
.record-text { font-size: 24rpx; color: var(--text-secondary); margin-top: 12rpx; display: block; }

.bait-row { display: flex; gap: 12rpx; flex-wrap: wrap; }

.tips-box {
  margin-top: 16rpx; padding: 20rpx; background: #E8F8EF;
  border-radius: var(--radius-sm); font-size: 24rpx; color: #10703D; line-height: 1.6;
}
