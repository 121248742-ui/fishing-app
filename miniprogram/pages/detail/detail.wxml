<view class="hero">
  <image src="{{fish.image}}" mode="aspectFit" class="hero-img"/>
</view>

<view class="card" style="text-align:center;">
  <view class="name">{{fish.name}}</view>
  <view class="tags-row">
    <text class="tag tag-gray">{{fish.type}}</text>
    <text class="tag {{fish.dietClass}}">{{fish.diet}}</text>
  </view>
  <view class="meta-row">
    <view class="meta-item"><text class="meta-lbl">稀有程度</text><text class="meta-val stars">{{fish.rarityStars}}</text></view>
    <view class="meta-item"><text class="meta-lbl">作钓难度</text><text class="meta-val diff">{{fish.diffDots}}</text></view>
  </view>
</view>

<view class="card">
  <view class="section-title">📋 基本信息</view>
  <text class="body-text">{{fish.habitat}}</text>
  <view class="peak-row">
    <text class="tag tag-green" wx:for="{{fish.peakMonths}}" wx:key="*this">旺季{{item}}月</text>
  </view>
  <text class="record-text">📏 {{fish.record}}</text>
</view>

<view class="card">
  <view class="section-title">🪱 推荐饵料</view>
  <view class="bait-row">
    <text class="tag-{{item.tier}}" wx:for="{{fish.bait}}" wx:key="name">{{item.name}}</text>
  </view>
</view>

<view class="card">
  <view class="section-title">🎣 作钓思路</view>
  <text class="body-text">{{fish.technique}}</text>
  <view class="tips-box">💡 {{fish.tips}}</view>
</view>

<view class="card">
  <view class="section-title">📸 我的渔获</view>
  <view wx:if="{{unlocked}}">
    <image wx:if="{{photo}}" src="{{photo}}" mode="aspectFit" class="catch-photo"/>
    <view class="catch-info">
      <text wx:if="{{weight}}">🎣 {{weight}}斤 · </text>
      <text>{{date}}</text>
      <text wx:if="{{spot}}"> · {{spot}}</text>
    </view>
    <button class="btn-small btn-danger" bindtap="lock">🔒 重新锁定</button>
  </view>
  <view wx:else>
    <view class="photo-upload" bindtap="choosePhoto">
      <image wx:if="{{photo}}" src="{{photo}}" mode="aspectFill" class="catch-upload-preview"/>
      <view wx:else class="photo-placeholder-small">
        <text style="font-size:48rpx;">📷</text>
        <text style="font-size:24rpx;color:#ccc;">上传渔获照片来解锁</text>
      </view>
    </view>
    <input class="form-input" placeholder="重量（斤）选填" value="{{weight}}" bindinput="onInput" data-field="weight"/>
    <view class="form-input pick-spot" bindtap="chooseSpot">{{spot || '📍 钓点 选填（点击选择）'}}</view>
    <button class="pub-btn" bindtap="unlock">🔓 解锁此鱼种</button>
  </view>
</view>
