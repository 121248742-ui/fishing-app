<view class="card" style="margin-top:20rpx;">
  <text class="section-title">📸 分享渔获</text>
  <view class="photo-upload" bindtap="choosePhoto">
    <image wx:if="{{photo}}" src="{{photo}}" mode="aspectFill" class="photo-preview"/>
    <view wx:else class="photo-placeholder">
      <text style="font-size:60rpx;">📷</text>
      <text style="font-size:24rpx;color:#ccc;">点击上传渔获照片</text>
    </view>
  </view>
  <input class="form-input" placeholder="鱼种名称（如：鲫鱼）" value="{{fishType}}" bindinput="onInput" data-field="fishType"/>
  <input class="form-input" placeholder="重量（斤）" value="{{weight}}" bindinput="onInput" data-field="weight"/>
  <input class="form-input" placeholder="钓点名称" value="{{spot}}" bindinput="onInput" data-field="spot"/>
  <textarea class="form-input form-textarea" placeholder="说点什么..." value="{{note}}" bindinput="onInput" data-field="note"/>
  <button class="pub-btn" bindtap="publish">发布</button>
</view>

<view wx:if="{{posts.length === 0}}" class="empty-state">
  <text style="font-size:80rpx;">🎣</text>
  <text style="font-size:28rpx;margin-top:16rpx;">还没有渔获分享</text>
</view>

<view class="post-list" wx:else>
  <view class="card post-card" wx:for="{{posts}}" wx:key="time">
    <!-- Header -->
    <view class="post-head">
      <image wx:if="{{item.userAvatar}}" src="{{item.userAvatar}}" class="post-avatar-img" mode="aspectFill"/>
      <view wx:else class="post-avatar-em">🎣</view>
      <view class="post-head-info">
        <text class="post-uname">{{item.userName}}</text>
        <text class="post-utime">{{item.timeAgo}}</text>
      </view>
      <text class="tag tag-green" wx:if="{{item.fishType}}">{{item.fishType}}</text>
    </view>

    <!-- Photo -->
    <view wx:if="{{item.photo}}" class="post-photo-wrap">
      <image src="{{item.photo}}" mode="aspectFill" class="post-photo"/>
      <view class="post-photo-meta" wx:if="{{item.weight || item.spot}}">
        <text wx:if="{{item.weight}}">⚖️ {{item.weight}}斤</text>
        <text wx:if="{{item.weight && item.spot}}"> · </text>
        <text wx:if="{{item.spot}}">📍 {{item.spot}}</text>
      </view>
    </view>

    <!-- Info without photo -->
    <view wx:elif="{{item.weight || item.spot}}" class="post-info-inline">
      <text wx:if="{{item.weight}}">⚖️ {{item.weight}}斤  </text>
      <text wx:if="{{item.spot}}">📍 {{item.spot}}</text>
    </view>

    <!-- Note -->
    <text wx:if="{{item.note}}" class="post-note-text">{{item.note}}</text>

    <!-- Actions -->
    <view class="post-foot">
      <view class="post-action {{item.liked ? 'liked' : ''}}" bindtap="toggleLike" data-idx="{{index}}">
        <text>{{item.liked ? '❤️' : '🤍'}} {{item.likes || 0}}</text>
      </view>
      <text class="post-del" bindtap="delPost" data-idx="{{index}}">删除</text>
    </view>
  </view>
</view>
