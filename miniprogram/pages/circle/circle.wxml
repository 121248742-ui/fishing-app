<view class="publish-btn" bindtap="openPost">
  <text>📸 分享渔获</text>
</view>

<view wx:if="{{posts.length === 0}}" class="empty-state">
  <text style="font-size:80rpx;">🎣</text>
  <text style="font-size:28rpx;margin-top:16rpx;">还没有渔获分享</text>
  <text style="font-size:24rpx;color:#ccc;margin-top:8rpx;">点击上方按钮，晒出你的渔获吧</text>
</view>

<view class="post-list" wx:else>
  <view class="card post" wx:for="{{posts}}" wx:key="time">
    <view class="post-header">
      <view class="post-avatar">🎣</view>
      <view class="post-user">
        <text class="post-name">钓鱼人</text>
        <text class="post-time">{{item.time}}</text>
      </view>
      <text class="tag tag-green" wx:if="{{item.fishType}}">{{item.fishType}}</text>
    </view>
    <image src="{{item.photo}}" mode="aspectFill" class="post-photo" wx:if="{{item.photo}}"/>
    <view class="post-body">
      <text wx:if="{{item.weight}}">⚖️ {{item.weight}}斤  </text>
      <text wx:if="{{item.spot}}">📍 {{item.spot}}</text>
      <text wx:if="{{item.note}}" class="post-note">{{item.note}}</text>
    </view>
    <view class="post-actions">
      <text>❤️ 0</text><text>💬 0</text>
      <text class="del-btn" bindtap="delPost" data-idx="{{index}}">删除</text>
    </view>
  </view>
</view>
