.photo-upload { margin-bottom: 16rpx; }
.photo-placeholder {
  border: 2rpx dashed #D0D5DD; border-radius: var(--radius-sm);
  padding: 48rpx; text-align: center; display: flex;
  flex-direction: column; align-items: center; gap: 8rpx;
}
.photo-preview { width: 100%; height: 320rpx; border-radius: var(--radius-sm); }

.form-input {
  width: 100%; padding: 18rpx 0; border-bottom: 1px solid #f0f0f0;
  font-size: 28rpx; margin-bottom: 4rpx;
}
.form-textarea { height: 120rpx; }
.pub-btn {
  background: linear-gradient(135deg, #1AAD5F, #2BD472); color: #fff;
  margin-top: 20rpx; border-radius: var(--radius-sm);
  font-size: 30rpx; font-weight: 700; text-align: center;
}

.post-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.post-avatar {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: linear-gradient(135deg, #E8F8EF, #C6F0D8);
  display: flex; align-items: center; justify-content: center; font-size: 32rpx;
}
.post-user { flex: 1; }
.post-name { font-size: 28rpx; font-weight: 700; display: block; }
.post-time { font-size: 22rpx; color: var(--text-secondary); }
.post-photo { width: 100%; border-radius: var(--radius-sm); max-height: 500rpx; margin-bottom: 16rpx; }
.post-body { font-size: 26rpx; color: #555; line-height: 1.8; }
.post-note { display: block; margin-top: 8rpx; color: #333; }
.post-actions { display: flex; gap: 30rpx; font-size: 24rpx; color: var(--text-secondary); margin-top: 16rpx; padding-top: 16rpx; border-top: 1px solid #f0f0f0; }
.del-btn { margin-left: auto; color: var(--danger); }
