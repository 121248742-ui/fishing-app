/* FAB */
.fab {
  position: fixed; bottom: calc(120rpx + env(safe-area-inset-bottom));
  right: 32rpx; z-index: 50;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: linear-gradient(135deg, #1AAD5F, #2BD472);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 8rpx 28rpx rgba(26,173,95,0.4);
}
.fab-icon { font-size: 48rpx; color: #fff; font-weight: 300; line-height: 1; }

/* Overlay */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300;
  display: flex; align-items: flex-end;
}
.overlay-mask { position: absolute; inset: 0; background: rgba(0,0,0,0.45); }
.overlay-panel {
  position: relative; width: 100%; max-height: 90vh;
  background: #fff; border-radius: 28rpx 28rpx 0 0;
  display: flex; flex-direction: column; overflow: hidden;
}
.overlay-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 32rpx; border-bottom: 1px solid #F0F2F5; flex-shrink: 0;
}
.overlay-title { font-size: 32rpx; font-weight: 700; }
.overlay-close { font-size: 36rpx; color: #999; padding: 8rpx; }
.overlay-body { padding: 24rpx 32rpx; overflow-y: auto; flex: 1; }

/* Form */
.photo-upload { margin-bottom: 16rpx; }
.photo-placeholder {
  border: 2rpx dashed #D0D5DD; border-radius: var(--radius-sm);
  padding: 48rpx; text-align: center; display: flex;
  flex-direction: column; align-items: center; gap: 8rpx;
}
.photo-preview { width: 100%; height: 320rpx; border-radius: var(--radius-sm); }
.form-input {
  width: 100%; padding: 18rpx 0; border-bottom: 1px solid #f0f0f0;
  font-size: 28rpx; margin-bottom: 4rpx;
}
.form-textarea { height: 120rpx; }
.pub-btn {
  background: linear-gradient(135deg, #1AAD5F, #2BD472); color: #fff;
  margin-top: 24rpx; border-radius: var(--radius-sm);
  font-size: 30rpx; font-weight: 700; text-align: center;
}

/* Waterfall */
.waterfall {
  display: flex; gap: 14rpx; padding: 14rpx 16rpx 160rpx;
}
.wf-col { flex: 1; display: flex; flex-direction: column; gap: 14rpx; }
.wf-card {
  background: #fff; border-radius: 14rpx; overflow: hidden;
  box-shadow: 0 1px 6px rgba(0,0,0,0.04);
}
.wf-img { width: 100%; display: block; }
.wf-img-empty {
  width: 100%; height: 280rpx; background: linear-gradient(135deg, #E8F8EF, #C6F0D8);
  display: flex; align-items: center; justify-content: center; font-size: 64rpx;
}
.wf-body { padding: 14rpx 16rpx 16rpx; }
.wf-title { font-size: 26rpx; font-weight: 700; display: block; }
.wf-desc {
  font-size: 22rpx; color: #777; display: -webkit-box;
  -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden;
  margin-top: 4rpx; line-height: 1.4;
}
.wf-foot { display: flex; align-items: center; gap: 8rpx; margin-top: 10rpx; }
.wf-avatar { width: 36rpx; height: 36rpx; border-radius: 50%; }
.wf-avatar-em {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  background: #E8F8EF; display: flex; align-items: center;
  justify-content: center; font-size: 20rpx;
}
.wf-name { font-size: 20rpx; color: #999; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.wf-like { font-size: 20rpx; color: #999; }

/* Detail */
.detail-photo { width: 100%; display: block; border-radius: var(--radius-sm); margin-bottom: 20rpx; }
.detail-info { margin-bottom: 20rpx; }
.detail-user { display: flex; align-items: center; gap: 12rpx; margin-bottom: 12rpx; }
.detail-avatar { width: 64rpx; height: 64rpx; border-radius: 50%; border: 2rpx solid #E8F8EF; }
.detail-avatar-em {
  width: 64rpx; height: 64rpx; border-radius: 50%;
  background: #E8F8EF; display: flex; align-items: center;
  justify-content: center; font-size: 32rpx; flex-shrink: 0;
}
.detail-username { font-size: 28rpx; font-weight: 600; display: block; }
.detail-time { font-size: 22rpx; color: var(--text-secondary); }
.detail-note { font-size: 28rpx; color: var(--text); line-height: 1.6; margin-bottom: 8rpx; }
.detail-meta { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.detail-actions { display: flex; align-items: center; gap: 24rpx; padding-bottom: 16rpx; border-bottom: 1px solid #F0F2F5; }
.detail-like { font-size: 28rpx; color: var(--text-secondary); }
.detail-like.active { color: #FA5151; }
.detail-del { font-size: 24rpx; color: #ccc; margin-left: auto; }

/* Comments */
.comment-section { padding: 20rpx 0 100rpx; }
.comment-title { font-size: 28rpx; font-weight: 700; display: block; margin-bottom: 16rpx; }
.comment-item { padding: 16rpx 0; border-bottom: 1rpx solid #F7F8FA; }
.comment-user { font-size: 26rpx; font-weight: 600; color: #555; }
.comment-text { font-size: 26rpx; color: var(--text); }
.comment-time { font-size: 20rpx; color: #ccc; margin-left: 12rpx; }
.comment-empty { text-align: center; color: #ccc; font-size: 24rpx; padding: 40rpx 0; }

.comment-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  border-top: 1px solid #F0F2F5; background: #fff; flex-shrink: 0;
}
.comment-input {
  flex: 1; padding: 14rpx 20rpx; background: #F7F8FA;
  border-radius: 40rpx; font-size: 26rpx;
}
.comment-send { font-size: 28rpx; color: #1AAD5F; font-weight: 600; flex-shrink: 0; }
