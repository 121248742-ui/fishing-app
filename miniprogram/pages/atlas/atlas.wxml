<!-- Login Card -->
<view class="header-banner" wx:if="{{hasLogin}}">
  <image class="login-bg" src="/images/user-bg.jpg" mode="aspectFill"/>
  <view class="user-row">
    <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img" mode="aspectFill"/>
    <view wx:else class="avatar-placeholder-small">🎣</view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '钓鱼达人'}}</text>
      <text class="user-sub">已登录 · 图鉴收藏中</text>
    </view>
  </view>
  <view class="stats-row">
    <view class="stat-item">
      <text class="stat-num">{{unlockedCount}}/{{totalCount}}</text>
      <text class="stat-lbl">图鉴</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{postCount}}</text>
      <text class="stat-lbl">帖子</text>
    </view>
    <view class="stat-item">
      <text class="stat-num">{{totalLikes}}</text>
      <text class="stat-lbl">获赞</text>
    </view>
  </view>
  <view class="share-banner" bindtap="shareAtlas">
    <text class="share-banner-icon">📤</text>
    <text class="share-banner-text">分享我的图鉴给好友</text>
  </view>
  <view class="logout-row" bindtap="doLogout"><text>退出登录</text></view>
</view>

<view class="header-banner login-banner" wx:else>
  <image class="login-bg" src="/images/user-bg.jpg" mode="aspectFill"/>
  <view class="login-box">
    <text class="login-sub">登录后记录你的钓鱼旅程</text>
    <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{tempAvatar}}" src="{{tempAvatar}}" class="pick-avatar-preview" mode="aspectFill"/>
      <view wx:else class="avatar-placeholder">📷</view>
    </button>
    <view class="pick-actions">
      <text class="pick-hint">点击获取微信头像</text>
      <text class="pick-or">或</text>
      <text class="pick-upload" bindtap="uploadAvatar">上传头像</text>
    </view>
    <input type="nickname" class="nickname-input" placeholder="点击获取微信昵称（必填）" bindinput="onNicknameInput" value="{{tempNickname}}"/>
    <button class="login-btn" bindtap="doLogin" disabled="{{!tempAvatar || !tempNickname}}">登录</button>
  </view>
</view>

<!-- Menu -->
<view wx:if="{{hasLogin}}" class="card menu-card">
  <view class="menu-item" bindtap="openSubPage" data-page="atlas">
    <view class="menu-icon green">🐟</view>
    <view class="menu-info">
      <text class="menu-label">我的图鉴</text>
      <text class="menu-desc">已解锁 {{unlockedCount}}/{{totalCount}} 种鱼</text>
    </view>
    <text class="menu-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="openSubPage" data-page="posts">
    <view class="menu-icon blue">📝</view>
    <view class="menu-info">
      <text class="menu-label">我的帖子</text>
      <text class="menu-desc">{{postCount}} 篇帖子</text>
    </view>
    <text class="menu-arrow">›</text>
  </view>
  <view class="menu-item" bindtap="openSubPage" data-page="likes">
    <view class="menu-icon orange">❤️</view>
    <view class="menu-info">
      <text class="menu-label">获赞与互动</text>
      <text class="menu-desc">{{newLikes > 0 || newComments > 0 ? '有新互动' : '共 ' + totalLikes + ' 个赞'}}</text>
    </view>
    <text class="menu-badge" wx:if="{{newLikes > 0 || newComments > 0}}">{{newLikes + newComments}}</text>
    <text class="menu-arrow">›</text>
  </view>
</view>

<!-- Sub Page: Atlas -->
<view wx:if="{{subPage === 'atlas'}}" class="sub-page">
  <view class="sub-head">
    <text class="sub-back" bindtap="closeSubPage">←</text>
    <text class="sub-title">我的图鉴</text>
  </view>
  <scroll-view scroll-y class="sub-body">
    <view wx:if="{{unlocked.length}}" class="section-label">🎯 已解锁 ({{unlocked.length}})</view>
    <view class="grid">
      <view class="cell unlocked" wx:for="{{unlocked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
        <text class="cell-name">{{item.name}}</text>
        <text class="cell-check">✅</text>
      </view>
    </view>
    <view wx:if="{{locked.length}}" class="section-label dim">🔒 未解锁 ({{locked.length}})</view>
    <view class="grid">
      <view class="cell locked" wx:for="{{locked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
        <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
        <text class="cell-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- Sub Page: My Posts -->
<view wx:if="{{subPage === 'posts'}}" class="sub-page">
  <view class="sub-head">
    <text class="sub-back" bindtap="closeSubPage">←</text>
    <text class="sub-title">我的帖子</text>
  </view>
  <scroll-view scroll-y class="sub-body">
    <view wx:if="{{myPosts.length === 0}}" class="empty-state">
      <text style="font-size:64rpx;">📝</text>
      <text style="font-size:28rpx;margin-top:16rpx;">还没有发过帖子</text>
    </view>
    <view class="mp-item" wx:for="{{myPosts}}" wx:key="time" bindtap="openMyPost" data-idx="{{index}}">
      <image wx:if="{{item.photo}}" src="{{item.photo}}" mode="aspectFill" class="mp-thumb"/>
      <view wx:else class="mp-thumb-empty">🎣</view>
      <view class="mp-info">
        <text class="mp-name">{{item.fishType || '渔获分享'}}</text>
        <text class="mp-note" wx:if="{{item.note}}">{{item.note}}</text>
        <text class="mp-meta">{{item.weight ? '⚖️' + item.weight + '斤  ' : ''}}{{item.timeAgo}}  ❤️ {{item.likes || 0}}  💬 {{item.comments ? item.comments.length : 0}}</text>
      </view>
      <view class="mp-actions">
        <text class="act-btn act-edit" catchtap="startEditMyPost" data-idx="{{index}}">✏️</text>
        <text class="act-btn act-del" catchtap="delMyPost" data-idx="{{index}}">🗑️</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- Sub Page: Likes -->
<view wx:if="{{subPage === 'likes'}}" class="sub-page">
  <view class="sub-head">
    <text class="sub-back" bindtap="closeSubPage">←</text>
    <text class="sub-title">获赞与互动</text>
  </view>
  <scroll-view scroll-y class="sub-body">
    <view wx:if="{{totalLikes === 0}}" class="empty-state">
      <text style="font-size:64rpx;">❤️</text>
      <text style="font-size:28rpx;margin-top:16rpx;">还没有收到赞</text>
      <text style="font-size:24rpx;color:#ccc;margin-top:8rpx;">去钓鱼圈分享渔获吧</text>
    </view>
    <view class="mp-item" wx:for="{{myPosts}}" wx:key="time" wx:if="{{item.likes > 0}}">
      <image wx:if="{{item.photo}}" src="{{item.photo}}" mode="aspectFill" class="mp-thumb"/>
      <view wx:else class="mp-thumb-empty">🎣</view>
      <view class="mp-info">
        <text class="mp-name">{{item.fishType || '渔获分享'}}</text>
        <text class="mp-meta">❤️ {{item.likes}} 个赞 · {{item.timeAgo}}</text>
      </view>
    </view>
    <view wx:if="{{noLikedPosts}}" class="empty-state">
      <text style="font-size:64rpx;">💬</text>
      <text style="font-size:28rpx;margin-top:16rpx;">还没有收到赞</text>
    </view>
  </scroll-view>
</view>

<!-- Share Atlas Sub Page -->
<view wx:if="{{subPage === 'share'}}" class="sub-page">
  <view class="sub-head">
    <text class="sub-back" bindtap="closeSubPage">←</text>
    <text class="sub-title">我的钓鱼图鉴</text>
  </view>
  <scroll-view scroll-y class="sub-body">
    <view class="share-summary">
      <text class="share-title">🎣 {{userInfo.nickName || '钓鱼达人'}} 的图鉴</text>
      <text class="share-stat">已解锁 {{unlockedCount}}/{{totalCount}} 种 · 完成度 {{sharePct}}%</text>
    </view>
    <view class="grid">
      <view class="cell unlocked" wx:for="{{unlocked}}" wx:key="id">
        <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
        <text class="cell-name">{{item.name}}</text>
      </view>
    </view>
    <view wx:if="{{locked.length}}" class="section-label dim" style="margin-top:16rpx;">🔒 未解锁 ({{locked.length}})</view>
    <view class="grid">
      <view class="cell locked" wx:for="{{locked}}" wx:key="id">
        <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
        <text class="cell-name">{{item.name}}</text>
      </view>
    </view>
  </scroll-view>
</view>

<!-- My Post Detail + Edit Overlay -->
<view wx:if="{{viewPost}}" class="overlay">
  <view class="overlay-mask" bindtap="closeViewPost"></view>
  <view class="overlay-panel">
    <view class="overlay-head">
      <text class="overlay-title">{{editing ? '编辑帖子' : '帖子详情'}}</text>
      <text class="overlay-close" bindtap="closeViewPost">✕</text>
    </view>
    <scroll-view scroll-y class="overlay-body">
      <view wx:if="{{editing}}">
        <view class="photo-upload" bindtap="editChoosePhoto">
          <image wx:if="{{editPhoto || viewPost.photo}}" src="{{editPhoto || viewPost.photo}}" mode="aspectFill" class="photo-preview"/>
          <view wx:else class="photo-placeholder"><text style="font-size:48rpx;">📷</text><text style="font-size:22rpx;color:#ccc;">点击更换照片</text></view>
        </view>
        <input class="form-input" placeholder="鱼种名称" value="{{editFishType}}" bindinput="onEditInput" data-field="editFishType"/>
        <input class="form-input" placeholder="重量（斤）" value="{{editWeight}}" bindinput="onEditInput" data-field="editWeight"/>
        <input class="form-input" placeholder="钓点名称" value="{{editSpot}}" bindinput="onEditInput" data-field="editSpot"/>
        <textarea class="form-input form-textarea" placeholder="说点什么..." value="{{editNote}}" bindinput="onEditInput" data-field="editNote"/>
        <view style="display:flex;gap:16rpx;margin-top:24rpx;">
          <button class="pub-btn" style="flex:1;background:#999;" bindtap="closeViewPost">取消</button>
          <button class="pub-btn" style="flex:1;" bindtap="saveEdit">保存</button>
        </view>
      </view>
      <view wx:else>
        <view class="detail-photo-wrap"><image wx:if="{{viewPost.photo}}" src="{{viewPost.photo}}" mode="widthFix" class="detail-photo"/></view>
        <view class="detail-info">
          <view class="detail-user">
            <view class="detail-avatar-em">🎣</view>
            <view><text class="detail-username">{{userInfo.nickName || '钓鱼人'}}</text><text class="detail-time">{{viewPost.timeAgo}}</text></view>
            <text class="tag tag-green" wx:if="{{viewPost.fishType}}">{{viewPost.fishType}}</text>
          </view>
          <text wx:if="{{viewPost.note}}" class="detail-note">{{viewPost.note}}</text>
          <view class="detail-meta" wx:if="{{viewPost.weight || viewPost.spot}}">
            <text wx:if="{{viewPost.weight}}">⚖️ {{viewPost.weight}}斤  </text><text wx:if="{{viewPost.spot}}">📍 {{viewPost.spot}}</text>
          </view>
          <view class="detail-actions">
            <text class="act-btn act-edit" bindtap="startEdit">✏️ 重新编辑</text>
            <text class="act-btn act-del" catchtap="delMyPost" data-idx="{{viewPostIdx}}">🗑️ 删除</text>
          </view>
        </view>
        <view class="comment-section">
          <text class="comment-title">💬 评论 ({{viewPost.comments ? viewPost.comments.length : 0}})</text>
          <view class="comment-item" wx:for="{{viewPost.comments}}" wx:key="time" wx:for-item="c" bindtap="replyToComment" data-name="{{c.userName}}">
            <text class="comment-user">{{c.userName}}</text>
            <text wx:if="{{c.replyTo}}" class="comment-reply"> 回复 {{c.replyTo}}</text>
            <text class="comment-text">: {{c.text}}</text>
            <text class="comment-time">{{c.timeAgo}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
    <view wx:if="{{!editing}}" class="comment-bar">
      <input class="comment-input" placeholder="{{replyTo ? '回复 ' + replyTo + '...' : '写评论...'}}" value="{{commentText}}" bindinput="onCommentInput" confirm-type="send" bindconfirm="sendMyComment"/>
      <text class="comment-send" bindtap="sendMyComment">发送</text>
    </view>
  </view>
</view>
