<!-- Logged In Card -->
<view class="header-banner" wx:if="{{hasLogin}}">
  <image lazy-load class="login-bg" src="/images/user-bg.jpg" mode="aspectFill"/>
  <view class="user-row">
    <image lazy-load wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img" mode="aspectFill"/>
    <view wx:else class="avatar-placeholder-small">🎣</view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '钓鱼达人'}}</text>
      <text class="user-sub">已登录 · 图鉴收藏中</text>
    </view>
  </view>
  <view class="stats-row">
    <view class="stat-item"><text class="stat-num">{{unlockedCount}}/{{totalCount}}</text><text class="stat-lbl">图鉴</text></view>
  </view>
  <view class="share-banner" bindtap="openSubPage" data-page="share">
    <text class="share-banner-icon">📤</text><text class="share-banner-text">分享我的图鉴给好友</text>
  </view>
  <view class="logout-row" bindtap="doLogout"><text>退出登录</text></view>
</view>

<!-- Login Card -->
<view class="header-banner login-banner" wx:else>
  <image lazy-load class="login-bg" src="/images/user-bg.jpg" mode="aspectFill"/>
  <view class="login-inner">
    <text class="login-welcome">解锁生涯钓鱼图鉴</text>
    <button class="avatar-zone" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image lazy-load wx:if="{{tempAvatar}}" src="{{tempAvatar}}" mode="aspectFill" class="avatar-preview"/>
      <view wx:else class="avatar-empty"><text>📷</text></view>
    </button>
    <view class="avatar-row">
      <text class="avatar-tip">获取微信头像</text>
      <text class="avatar-or">|</text>
      <text class="avatar-custom" bindtap="pickAvatar">本地上传</text>
    </view>
    <input type="nickname" class="name-input" placeholder="点击获取微信昵称" bindinput="onNicknameInput" value="{{tempNickname}}"/>
    <button class="submit-btn" bindtap="doLogin">登 录</button>
  </view>
</view>

<!-- Atlas Grid -->
<view wx:if="{{hasLogin}}" class="atlas-main">
  <view wx:if="{{unlocked.length}}" class="section-label">🎯 已解锁 ({{unlocked.length}})</view>
  <view class="grid">
    <view class="cell unlocked" wx:for="{{unlocked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image lazy-load src="{{item.image}}" mode="aspectFit" class="cell-img"/><text class="cell-name">{{item.name}}</text><text class="cell-check">✅</text>
    </view>
  </view>
  <view wx:if="{{locked.length}}" class="section-label dim">🔒 未解锁 ({{locked.length}})</view>
  <view class="grid">
    <view class="cell locked" wx:for="{{locked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image lazy-load src="{{item.image}}" mode="aspectFit" class="cell-img"/><text class="cell-name">{{item.name}}</text>
    </view>
  </view>
</view>

<!-- Share Sub Page -->
<view wx:if="{{subPage === 'share'}}" class="sub-page">
  <view class="sub-head"><text class="sub-back" bindtap="closeSubPage">←</text><text class="sub-title">我的钓鱼图鉴</text></view>
  <scroll-view scroll-y class="sub-body">
    <view class="share-summary"><text class="share-title">🎣 {{userInfo.nickName || '钓鱼达人'}} 的图鉴</text><text class="share-stat">已解锁 {{unlockedCount}}/{{totalCount}} 种 · 完成度 {{sharePct}}%</text></view>
    <view class="grid"><view class="cell unlocked" wx:for="{{unlocked}}" wx:key="id"><image lazy-load src="{{item.image}}" mode="aspectFit" class="cell-img"/><text class="cell-name">{{item.name}}</text></view></view>
    <view wx:if="{{locked.length}}" class="section-label dim" style="margin-top:16rpx;">🔒 未解锁 ({{locked.length}})</view>
    <view class="grid"><view class="cell locked" wx:for="{{locked}}" wx:key="id"><image lazy-load src="{{item.image}}" mode="aspectFit" class="cell-img"/><text class="cell-name">{{item.name}}</text></view></view>
  </scroll-view>
</view>
