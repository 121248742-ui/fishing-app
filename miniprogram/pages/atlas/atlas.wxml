<view wx:if="{{hasLogin}}" style="padding:100rpx;text-align:center;">
  <text style="font-size:40rpx;">已登录</text>
</view>

<view wx:else style="margin:24rpx 16rpx;padding:56rpx 32rpx;border-radius:14px;background:linear-gradient(135deg,#1A7A3D,#1AAD5F);color:#fff;display:flex;flex-direction:column;align-items:center;gap:20rpx;">
  <view bindtap="pickAvatar" style="width:140rpx;height:140rpx;border-radius:50%;background:rgba(255,255,255,0.25);border:3rpx dashed rgba(255,255,255,0.5);display:flex;align-items:center;justify-content:center;">
    <image wx:if="{{tempAvatar}}" src="{{tempAvatar}}" mode="aspectFill" style="width:140rpx;height:140rpx;border-radius:50%;"/>
    <text wx:else style="font-size:56rpx;">📷</text>
  </view>
  <text style="font-size:24rpx;opacity:0.85;">点击上传头像</text>
  <input placeholder="请输入昵称" bindinput="onNicknameInput" value="{{tempNickname}}" style="background:rgba(255,255,255,0.25);color:#fff;text-align:center;padding:16rpx 40rpx;border-radius:40rpx;font-size:28rpx;width:400rpx;"/>
  <button bindtap="doLogin" style="background:#fff;color:#1AAD5F;font-size:30rpx;font-weight:700;padding:18rpx 80rpx;border-radius:44rpx;">登录</button>
</view>
