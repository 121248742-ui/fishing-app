<view class="header-banner">
  <!-- WeChat Login -->
  <view wx:if="{{!hasLogin}}">
    <view class="login-box">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img"/>
        <view wx:else class="avatar-placeholder">🎣</view>
      </button>
      <input type="nickname" class="nickname-input" placeholder="点击设置昵称" bindinput="onNicknameInput" value="{{userInfo.nickName || ''}}"/>
      <button class="login-btn" bindtap="doLogin">微信一键登录</button>
    </view>
  </view>

  <view wx:else>
    <view class="user-row">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img"/>
      <view wx:else class="avatar-placeholder small">🎣</view>
      <view class="user-info">
        <text class="user-name">{{userInfo.nickName || '钓鱼达人'}}</text>
        <text class="user-sub">已登录 · 图鉴收藏中</text>
      </view>
    </view>
    <view class="stats">
      <text class="count">{{unlockedCount}}/{{totalCount}}</text>
      <view class="progress-bar">
        <view class="progress-fill" style="width:{{pct}}%"></view>
      </view>
    </view>
    <view class="logout-row" bindtap="doLogout">
      <text>退出登录</text>
    </view>
  </view>
</view>

<view wx:if="{{!hasLogin}}" class="empty-state" style="padding-top:60rpx;">
  <text style="font-size:60rpx;">🔒</text>
  <text style="font-size:28rpx;margin-top:16rpx;">登录后查看图鉴</text>
</view>

<block wx:else>
  <view wx:if="{{unlocked.length}}" class="section-label">已解锁 ({{unlocked.length}})</view>
  <view class="grid">
    <view class="cell unlocked" wx:for="{{unlocked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
      <text class="cell-name">{{item.name}}</text>
      <text class="cell-check">✅</text>
    </view>
  </view>

  <view wx:if="{{locked.length}}" class="section-label dim">未解锁 ({{locked.length}})</view>
  <view class="grid">
    <view class="cell locked" wx:for="{{locked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
      <text class="cell-name">{{item.name}}</text>
    </view>
  </view>
</block>
