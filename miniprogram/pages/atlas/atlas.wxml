<view class="header-banner" wx:if="{{hasLogin}}">
  <view class="user-row">
    <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img" mode="aspectFill"/>
    <view wx:else class="avatar-placeholder-small">🎣</view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '钓鱼达人'}}</text>
      <text class="user-sub">已登录 · 图鉴收藏中</text>
    </view>
  </view>

  <view class="progress-section">
    <view class="progress-header">
      <text class="progress-title">📊 解锁进度</text>
      <text class="progress-count">{{unlockedCount}} / {{totalCount}}</text>
    </view>
    <view class="progress-bar">
      <view class="progress-fill" style="width:{{pct}}%"></view>
    </view>
    <view class="progress-detail">
      <view class="pd-item">
        <text class="pd-num">{{unlocked.length}}</text>
        <text class="pd-lbl">已解锁</text>
      </view>
      <view class="pd-item">
        <text class="pd-num">{{postCount}}</text>
        <text class="pd-lbl">帖子</text>
      </view>
      <view class="pd-item">
        <text class="pd-num">{{totalLikes}}</text>
        <text class="pd-lbl">获赞</text>
      </view>
    </view>
  </view>

  <view class="logout-row" bindtap="doLogout">
    <text>退出登录</text>
  </view>
</view>

<view class="header-banner" wx:else>
  <view class="login-box">
    <button class="avatar-pick-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
      <image wx:if="{{tempAvatar}}" src="{{tempAvatar}}" class="pick-avatar-preview" mode="aspectFill"/>
      <view wx:else class="avatar-placeholder">📷</view>
    </button>
    <view class="pick-hint">点击头像获取微信头像</view>
    <input type="nickname" class="nickname-input" placeholder="点击获取微信昵称" bindinput="onNicknameInput" value="{{tempNickname}}"/>
    <button class="login-btn" bindtap="doLogin">登录</button>
  </view>
</view>

<view wx:if="{{!hasLogin}}" class="empty-state" style="padding-top:40rpx;">
  <text style="font-size:60rpx;">🔒</text>
  <text style="font-size:28rpx;margin-top:16rpx;">登录后查看图鉴</text>
</view>

<block wx:else>
  <view wx:if="{{unlocked.length}}" class="section-label">🎯 已解锁 ({{unlocked.length}})</view>
  <view class="grid">
    <view class="cell unlocked" wx:for="{{unlocked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
      <text class="cell-name">{{item.name}}</text>
      <text class="cell-check">✅</text>
    </view>
  </view>

  <view wx:if="{{locked.length}}" class="section-label dim">🔒 未解锁 ({{locked.length}})</view>
  <view class="grid">
    <view class="cell locked" wx:for="{{locked}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <image src="{{item.image}}" mode="aspectFit" class="cell-img"/>
      <text class="cell-name">{{item.name}}</text>
    </view>
  </view>
<view wx:if="{{myPosts.length}}" class="section-label" style="margin-top:8rpx;">📝 我的帖子 ({{myPosts.length}})</view>
<view class="my-post-list">
  <view class="card my-post" wx:for="{{myPosts}}" wx:key="time">
    <view class="mp-left">
      <text class="mp-title">{{item.fishType || '渔获分享'}}</text>
      <text class="mp-meta">{{item.weight ? item.weight + '斤 · ' : ''}}{{item.timeAgo}}</text>
      <text class="mp-meta" wx:if="{{item.spot}}">📍 {{item.spot}}</text>
    </view>
    <image wx:if="{{item.photo}}" src="{{item.photo}}" mode="aspectFill" class="mp-thumb"/>
    <view wx:else class="mp-thumb-empty">🎣</view>
    <text class="mp-del" bindtap="delMyPost" data-idx="{{index}}">✕</text>
  </view>
</view>
</block>
