.header-banner {
  margin: 24rpx 16rpx; padding: 32rpx; border-radius: var(--radius);
  background: linear-gradient(135deg, #1AAD5F, #2BD472); color: #fff;
}

/* Login */
.login-box { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.avatar-pick-btn {
  width: 140rpx; height: 140rpx; border-radius: 50%; padding: 0; margin: 0;
  background: rgba(255,255,255,0.15); border: 4rpx dashed rgba(255,255,255,0.4);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.avatar-pick-btn::after { border: none; }
.pick-avatar-preview { width: 100%; height: 100%; border-radius: 50%; }
.avatar-placeholder { font-size: 48rpx; }
.pick-hint { font-size: 22rpx; opacity: 0.7; }
.nickname-input {
  background: rgba(255,255,255,0.15); color: #fff; text-align: center;
  padding: 14rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; width: 360rpx;
}
.nickname-input::placeholder { color: rgba(255,255,255,0.5); }
.login-btn {
  background: rgba(255,255,255,0.95); color: #07C160; font-size: 28rpx;
  font-weight: 600; padding: 16rpx 60rpx; border-radius: 40rpx; line-height: 1; margin-top: 8rpx;
}

/* Logged in */
.user-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.avatar-img { width: 96rpx; height: 96rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.5); flex-shrink: 0; }
.avatar-placeholder-small {
  width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center; font-size: 44rpx;
}
.user-name { font-size: 32rpx; font-weight: 700; display: block; }
.user-sub { font-size: 22rpx; opacity: 0.85; }

/* Stats row */
.stats-row {
  display: flex; justify-content: space-around;
  background: rgba(255,255,255,0.15); border-radius: 16rpx;
  padding: 28rpx 16rpx;
}
.stat-item { text-align: center; }
.stat-num { font-size: 44rpx; font-weight: 800; display: block; line-height: 1; }
.stat-lbl { font-size: 22rpx; opacity: 0.8; margin-top: 6rpx; }

.logout-row { text-align: center; margin-top: 20rpx; opacity: 0.6; font-size: 22rpx; }

/* Section menus */
.menu-card { margin: 20rpx 16rpx; }
.menu-item {
  display: flex; align-items: center; gap: 18rpx;
  padding: 24rpx 0;
}
.menu-item + .menu-item { border-top: 1rpx solid #F0F2F5; }
.menu-icon {
  width: 72rpx; height: 72rpx; border-radius: 18rpx; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 32rpx;
}
.menu-icon.green { background: #E8F8EF; }
.menu-icon.blue { background: #EFF6FF; }
.menu-icon.orange { background: #FFF3E0; }
.menu-info { flex: 1; min-width: 0; }
.menu-label { font-size: 28rpx; font-weight: 600; display: block; }
.menu-desc { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 4rpx; }
.menu-badge {
  background: #FA5151; color: #fff; font-size: 20rpx; font-weight: 700;
  padding: 4rpx 14rpx; border-radius: 20rpx; margin-right: 8rpx;
}
.menu-arrow { font-size: 32rpx; color: #ccc; }

/* Sub-page overlay */
.sub-page {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: #F0F2F5; z-index: 250;
  display: flex; flex-direction: column;
}
.sub-head {
  background: #fff; padding: 20rpx 24rpx;
  display: flex; align-items: center; gap: 16rpx;
  border-bottom: 1rpx solid #EBEDF0;
}
.sub-back { font-size: 32rpx; color: var(--text); padding: 8rpx; }
.sub-title { font-size: 32rpx; font-weight: 700; }
.sub-body { flex: 1; overflow-y: auto; padding: 16rpx; }

/* My Posts list */
.mp-item {
  display: flex; align-items: center; gap: 16rpx;
  background: #fff; border-radius: var(--radius); padding: 20rpx;
  margin-bottom: 12rpx; box-shadow: var(--shadow-sm);
}
.mp-thumb {
  width: 120rpx; height: 120rpx; border-radius: var(--radius-sm);
  flex-shrink: 0; object-fit: cover;
}
.mp-thumb-empty {
  width: 120rpx; height: 120rpx; border-radius: var(--radius-sm);
  flex-shrink: 0; background: #F7F8FA;
  display: flex; align-items: center; justify-content: center; font-size: 48rpx;
}
.mp-info { flex: 1; min-width: 0; }
.mp-name { font-size: 28rpx; font-weight: 700; display: block; }
.mp-note {
  font-size: 24rpx; color: #555; display: block; margin-top: 4rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.mp-meta { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 6rpx; }
.mp-del-btn {
  background: none; color: #FA5151; font-size: 22rpx;
  padding: 8rpx 16rpx; border: 1rpx solid #FDE8E8; border-radius: 20rpx;
}

.section-label { font-size: 28rpx; font-weight: 700; margin: 0 16rpx 16rpx; }
.section-label.dim { color: var(--text-secondary); }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; padding: 0 16rpx 24rpx; }
.cell { background: #fff; border-radius: var(--radius); padding: 24rpx 12rpx; text-align: center; position: relative; box-shadow: var(--shadow-sm); }
.cell.locked { opacity: 0.4; }
.cell-img { width: 140rpx; height: 140rpx; display: block; margin: 0 auto; }
.cell-name { font-size: 24rpx; font-weight: 600; margin-top: 12rpx; display: block; }
.cell-check { position: absolute; top: 12rpx; right: 16rpx; font-size: 28rpx; }

/* Overlay shared */
.overlay {position:fixed;top:0;left:0;right:0;bottom:0;z-index:300;display:flex;align-items:flex-end}
.overlay-mask {position:absolute;inset:0;background:rgba(0,0,0,0.45)}
.overlay-panel {position:relative;width:100%;max-height:90vh;background:#fff;border-radius:28rpx 28rpx 0 0;display:flex;flex-direction:column;overflow:hidden}
.overlay-head {display:flex;justify-content:space-between;align-items:center;padding:28rpx 32rpx;border-bottom:1px solid #F0F2F5;flex-shrink:0}
.overlay-title {font-size:32rpx;font-weight:700}
.overlay-close {font-size:36rpx;color:#999;padding:8rpx}
.overlay-body {padding:24rpx 32rpx;overflow-y:auto;flex:1}

/* Edit form */
.photo-upload {margin-bottom:16rpx}
.photo-placeholder {border:2rpx dashed #D0D5DD;border-radius:var(--radius-sm);padding:48rpx;text-align:center;display:flex;flex-direction:column;align-items:center;gap:8rpx}
.photo-preview {width:100%;height:320rpx;border-radius:var(--radius-sm)}
.form-input {width:100%;padding:18rpx 0;border-bottom:1px solid #f0f0f0;font-size:28rpx;margin-bottom:4rpx}
.form-textarea {height:120rpx}
.pub-btn {background:linear-gradient(135deg,#1AAD5F,#2BD472);color:#fff;margin-top:24rpx;border-radius:var(--radius-sm);font-size:30rpx;font-weight:700;text-align:center}

/* Detail */
.detail-photo {width:100%;display:block;border-radius:var(--radius-sm);margin-bottom:20rpx}
.detail-info {margin-bottom:20rpx}
.detail-user {display:flex;align-items:center;gap:12rpx;margin-bottom:12rpx}
.detail-avatar-em {width:64rpx;height:64rpx;border-radius:50%;background:#E8F8EF;display:flex;align-items:center;justify-content:center;font-size:32rpx;flex-shrink:0}
.detail-username {font-size:28rpx;font-weight:600;display:block}
.detail-time {font-size:22rpx;color:var(--text-secondary)}
.detail-note {font-size:28rpx;color:var(--text);line-height:1.6;margin-bottom:8rpx}
.detail-meta {font-size:24rpx;color:var(--text-secondary);margin-bottom:12rpx}
.detail-actions {display:flex;align-items:center;gap:24rpx;padding:0 8rpx 16rpx;border-bottom:1px solid #F0F2F5}
.detail-like {font-size:28rpx;color:var(--text-secondary)}
.act-btn {font-size:24rpx;padding:8rpx 24rpx;border-radius:20rpx;margin-left:20rpx}
.act-edit {color:#1AAD5F;background:#E8F8EF}
.act-del {color:#FA5151;background:#FDE8E8}

/* Comments */
.comment-section {padding:20rpx 0 100rpx}
.comment-title {font-size:28rpx;font-weight:700;display:block;margin-bottom:16rpx}
.comment-item {padding:16rpx 0;border-bottom:1rpx solid #F7F8FA}
.comment-user {font-size:26rpx;font-weight:600;color:#555}
.comment-reply {font-size:24rpx;color:#1AAD5F}
.comment-text {font-size:26rpx;color:var(--text)}
.comment-time {font-size:20rpx;color:#ccc;margin-left:12rpx}
.comment-bar {display:flex;align-items:center;gap:16rpx;padding:16rpx 24rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom));border-top:1px solid #F0F2F5;background:#fff;flex-shrink:0}
.comment-input {flex:1;padding:14rpx 20rpx;background:#F7F8FA;border-radius:40rpx;font-size:26rpx}
.comment-send {font-size:28rpx;color:#1AAD5F;font-weight:600;flex-shrink:0}

/* My posts arrow */
.mp-arrow {font-size:32rpx;color:#ccc;flex-shrink:0}
