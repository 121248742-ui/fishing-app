.header-banner {
  position: relative; margin: 24rpx 16rpx; padding: 32rpx; border-radius: var(--radius);
  background: linear-gradient(135deg, #1AAD5F, #2BD472); color: #fff; min-height: 280rpx;
}

/* Login */
.login-box { display: flex; flex-direction: column; align-items: center; gap: 20rpx; }
.avatar-btn {
  width: 120rpx; height: 120rpx; border-radius: 50%; padding: 0; margin: 0;
  background: transparent; border: 4rpx solid rgba(255,255,255,0.5);
  display: flex; align-items: center; justify-content: center;
  overflow: hidden; line-height: 1;
}
.avatar-btn::after { border: none; }
.avatar-placeholder {
  width: 120rpx; height: 120rpx; border-radius: 50%;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center; font-size: 56rpx;
}
.avatar-placeholder.small { width: 96rpx; height: 96rpx; font-size: 44rpx; flex-shrink: 0; }
.avatar-img { width: 100%; height: 100%; border-radius: 50%; }
.nickname-input {
  background: rgba(255,255,255,0.2); color: #fff; text-align: center;
  padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 28rpx;
  width: 300rpx;
}
.nickname-input::placeholder { color: rgba(255,255,255,0.6); }
.login-btn {
  background: rgba(255,255,255,0.95); color: #07C160; font-size: 28rpx;
  font-weight: 600; padding: 16rpx 48rpx; border-radius: 40rpx;
  border: none; line-height: 1;
}

/* Logged in */
.user-row { display: flex; align-items: center; gap: 20rpx; }
.user-name { font-size: 32rpx; font-weight: 700; display: block; }
.user-sub { font-size: 22rpx; opacity: 0.85; }
.stats { position: absolute; bottom: 28rpx; right: 28rpx; text-align: right; }
.count { font-size: 56rpx; font-weight: 800; line-height: 1; }
.progress-bar { width: 200rpx; height: 10rpx; background: rgba(255,255,255,0.3); border-radius: 6rpx; margin-top: 16rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #fff; border-radius: 6rpx; }
.logout-row { position: absolute; bottom: 28rpx; left: 32rpx; opacity: 0.7; font-size: 22rpx; }

.section-label { font-size: 28rpx; font-weight: 700; margin: 0 16rpx 16rpx; }
.section-label.dim { color: var(--text-secondary); }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; padding: 0 16rpx 24rpx; }
.cell { background: #fff; border-radius: var(--radius); padding: 24rpx 12rpx; text-align: center; position: relative; box-shadow: var(--shadow-sm); }
.cell.locked { opacity: 0.4; }
.cell-img { width: 140rpx; height: 140rpx; display: block; margin: 0 auto; }
.cell-name { font-size: 24rpx; font-weight: 600; margin-top: 12rpx; display: block; }
.cell-check { position: absolute; top: 12rpx; right: 16rpx; font-size: 28rpx; }
