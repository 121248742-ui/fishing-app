.header-banner {
  margin: 24rpx 16rpx; padding: 32rpx; border-radius: var(--radius);
  color: #fff; position: relative; overflow: hidden;
  background: rgba(0,0,0,0.45);
}
.login-bg {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%;
  z-index: 0; border-radius: var(--radius);
}
.header-banner::after {
  content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  border-radius: var(--radius); background: rgba(0,0,0,0.35); z-index: 0;
}

.header-banner .user-row,
.header-banner .share-banner,
.header-banner .stats-row,
.header-banner .logout-row,
.header-banner .login-box,
.header-banner .login-inner { position: relative; z-index: 2; }

/* Login Card */
.login-banner { padding: 56rpx 32rpx; background: rgba(0,0,0,0.4); }
.login-inner { display: flex; flex-direction: column; align-items: center; gap: 20rpx; position: relative; z-index: 2; }
.login-welcome { font-size: 28rpx; font-weight: 600; opacity: 0.9; margin-bottom: 8rpx; }
.avatar-zone {
  width: 140rpx; height: 140rpx; border-radius: 50%; padding: 0;
  background: rgba(255,255,255,0.2); border: 3rpx dashed rgba(255,255,255,0.45);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.avatar-zone::after { border: none; }
.avatar-preview { width: 140rpx; height: 140rpx; border-radius: 50%; }
.avatar-empty { font-size: 56rpx; }
.avatar-tip { font-size: 24rpx; opacity: 0.8; }
.avatar-row { display: flex; align-items: center; gap: 12rpx; }
.avatar-or { font-size: 22rpx; opacity: 0.35; }
.avatar-custom { font-size: 24rpx; opacity: 0.8; text-decoration: underline; }
.name-input {
  background: rgba(255,255,255,0.2); color: #fff; text-align: center;
  padding: 16rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; width: 420rpx;
}
.name-input::placeholder { color: rgba(255,255,255,0.5); }
.submit-btn {
  background: #fff; color: #1AAD5F; font-size: 30rpx; font-weight: 700;
  padding: 18rpx 100rpx; border-radius: 44rpx; line-height: 1; margin-top: 12rpx;
}

/* Logged in */
.user-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.avatar-img { width: 96rpx; height: 96rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.5); flex-shrink: 0; }
.avatar-placeholder-small {
  width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center; font-size: 44rpx;
}
.user-name { font-size: 32rpx; font-weight: 700; display: block; }
.user-sub { font-size: 22rpx; opacity: 0.85; }

/* Stats */
.stats-row {
  display: flex; justify-content: space-around;
  background: rgba(255,255,255,0.15); border-radius: 16rpx; padding: 28rpx 16rpx;
}
.stat-item { text-align: center; }
.stat-num { font-size: 44rpx; font-weight: 800; display: block; line-height: 1; }
.stat-lbl { font-size: 22rpx; opacity: 0.8; margin-top: 6rpx; }
.logout-row { text-align: center; margin-top: 20rpx; opacity: 0.6; font-size: 22rpx; }

.share-banner {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  margin-top: 20rpx; padding: 20rpx; background: rgba(255,255,255,0.2);
  border-radius: 16rpx; border: 1rpx dashed rgba(255,255,255,0.4);
}
.share-banner-icon { font-size: 32rpx; }
.share-banner-text { font-size: 26rpx; font-weight: 600; }

/* Atlas Grid */
.atlas-main { margin-top: 24rpx; }
.section-label { font-size: 28rpx; font-weight: 700; margin: 0 16rpx 16rpx; }
.section-label.dim { color: var(--text-secondary); }
.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; padding: 0 16rpx 24rpx; }
.cell { background: #fff; border-radius: var(--radius); padding: 24rpx 12rpx; text-align: center; position: relative; box-shadow: var(--shadow-sm); }
.cell.locked { opacity: 0.4; }
.cell-img { width: 140rpx; height: 140rpx; display: block; margin: 0 auto; }
.cell-name { font-size: 24rpx; font-weight: 600; margin-top: 12rpx; display: block; }
.cell-check { position: absolute; top: 12rpx; right: 16rpx; font-size: 28rpx; }

/* Sub pages */
.sub-page { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: #F0F2F5; z-index: 250; display: flex; flex-direction: column; }
.sub-head { background: #fff; padding: 20rpx 24rpx; display: flex; align-items: center; gap: 16rpx; border-bottom: 1rpx solid #EBEDF0; }
.sub-back { font-size: 32rpx; color: var(--text); padding: 8rpx; }
.sub-title { font-size: 32rpx; font-weight: 700; }
.sub-body { flex: 1; overflow-y: auto; padding: 16rpx; }

.share-summary { text-align: center; padding: 24rpx 0; margin-bottom: 16rpx; }
.share-title { font-size: 36rpx; font-weight: 800; display: block; }
.share-stat { font-size: 26rpx; color: var(--text-secondary); margin-top: 8rpx; display: block; }
