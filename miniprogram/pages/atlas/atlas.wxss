.header-banner {
  margin: 24rpx 16rpx; padding: 32rpx; border-radius: var(--radius);
  background: linear-gradient(135deg, #1AAD5F, #2BD472); color: #fff;
}

/* Login */
.login-box { display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.avatar-pick-btn {
  width: 140rpx; height: 140rpx; border-radius: 50%; padding: 0; margin: 0;
  background: rgba(255,255,255,0.15); border: 4rpx dashed rgba(255,255,255,0.4);
  display: flex; align-items: center; justify-content: center; overflow: hidden;
}
.avatar-pick-btn::after { border: none; }
.pick-avatar-preview { width: 100%; height: 100%; border-radius: 50%; }
.avatar-placeholder { font-size: 48rpx; }
.pick-hint { font-size: 22rpx; opacity: 0.7; }
.nickname-input {
  background: rgba(255,255,255,0.15); color: #fff; text-align: center;
  padding: 14rpx 40rpx; border-radius: 40rpx; font-size: 28rpx;
  width: 360rpx;
}
.nickname-input::placeholder { color: rgba(255,255,255,0.5); }
.login-btn {
  background: rgba(255,255,255,0.95); color: #07C160; font-size: 28rpx;
  font-weight: 600; padding: 16rpx 60rpx; border-radius: 40rpx;
  border: none; line-height: 1; margin-top: 8rpx;
}

/* Logged in */
.user-row { display: flex; align-items: center; gap: 20rpx; margin-bottom: 24rpx; }
.avatar-img { width: 96rpx; height: 96rpx; border-radius: 50%; border: 4rpx solid rgba(255,255,255,0.5); flex-shrink: 0; }
.avatar-placeholder-small {
  width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0;
  background: rgba(255,255,255,0.2); display: flex;
  align-items: center; justify-content: center; font-size: 44rpx;
}
.user-name { font-size: 32rpx; font-weight: 700; display: block; }
.user-sub { font-size: 22rpx; opacity: 0.85; }

/* Progress */
.progress-section {
  background: rgba(255,255,255,0.15); border-radius: 16rpx;
  padding: 24rpx; backdrop-filter: blur(10rpx);
}
.progress-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.progress-title { font-size: 26rpx; font-weight: 600; }
.progress-count { font-size: 30rpx; font-weight: 800; }
.progress-bar { width: 100%; height: 10rpx; background: rgba(255,255,255,0.25); border-radius: 6rpx; overflow: hidden; }
.progress-fill { height: 100%; background: #fff; border-radius: 6rpx; transition: width 0.5s; }
.progress-detail { display: flex; justify-content: space-around; margin-top: 20rpx; }
.pd-item { text-align: center; }
.pd-num { font-size: 36rpx; font-weight: 800; display: block; line-height: 1; }
.pd-lbl { font-size: 20rpx; opacity: 0.75; margin-top: 4rpx; }

.logout-row { text-align: center; margin-top: 20rpx; opacity: 0.6; font-size: 22rpx; }

.section-label { font-size: 28rpx; font-weight: 700; margin: 0 16rpx 16rpx; }
.section-label.dim { color: var(--text-secondary); }

.grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; padding: 0 16rpx 24rpx; }
.cell { background: #fff; border-radius: var(--radius); padding: 24rpx 12rpx; text-align: center; position: relative; box-shadow: var(--shadow-sm); }
.cell.locked { opacity: 0.4; }
.cell-img { width: 140rpx; height: 140rpx; display: block; margin: 0 auto; }
.cell-name { font-size: 24rpx; font-weight: 600; margin-top: 12rpx; display: block; }
.cell-check { position: absolute; top: 12rpx; right: 16rpx; font-size: 28rpx; }

/* My Posts */
.my-post-list { margin-bottom: 24rpx; }
.my-post {
  display: flex; align-items: center; gap: 18rpx;
  margin-bottom: 12rpx; padding: 20rpx 24rpx;
  position: relative;
}
.mp-center { flex: 1; min-width: 0; }
.mp-title { font-size: 28rpx; font-weight: 700; display: block; }
.mp-desc {
  font-size: 24rpx; color: #555; display: block;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-top: 4rpx;
}
.mp-meta { font-size: 22rpx; color: var(--text-secondary); display: block; margin-top: 6rpx; }
.mp-thumb {
  width: 112rpx; height: 112rpx; border-radius: var(--radius-sm);
  flex-shrink: 0; object-fit: cover;
}
.mp-thumb-empty {
  width: 112rpx; height: 112rpx; border-radius: var(--radius-sm);
  flex-shrink: 0; background: #F7F8FA;
  display: flex; align-items: center; justify-content: center; font-size: 44rpx;
}
.mp-arrow { font-size: 36rpx; color: #ccc; flex-shrink: 0; }
.mp-del {
  position: absolute; top: 8rpx; right: 12rpx;
  font-size: 28rpx; color: #ccc; padding: 4rpx 8rpx;
}

/* Overlay */
.overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300;
  display: flex; align-items: flex-end;
}
.overlay-mask { position: absolute; inset: 0; background: rgba(0,0,0,0.45); }
.overlay-panel {
  position: relative; width: 100%; max-height: 80vh;
  background: #fff; border-radius: 28rpx 28rpx 0 0;
  display: flex; flex-direction: column; overflow: hidden;
}
.overlay-head {
  display: flex; justify-content: space-between; align-items: center;
  padding: 28rpx 32rpx; border-bottom: 1px solid #F0F2F5;
}
.overlay-title { font-size: 32rpx; font-weight: 700; }
.overlay-close { font-size: 36rpx; color: #999; padding: 8rpx; }
.overlay-body { padding: 24rpx 32rpx; overflow-y: auto; flex: 1; }

.view-photo { width: 100%; max-height: 500rpx; border-radius: var(--radius-sm); margin-bottom: 20rpx; }
.view-info { font-size: 26rpx; color: var(--text-secondary); display: flex; gap: 20rpx; flex-wrap: wrap; }
.view-time { color: #ccc; }
.view-note { display: block; margin-top: 16rpx; font-size: 28rpx; color: var(--text); line-height: 1.7; }
