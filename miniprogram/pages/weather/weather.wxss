/* Spot Section */
.spot-section { margin-top: 20rpx; }
.spot-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.spot-title { font-size: 28rpx; font-weight: 700; }
.add-btn {
  background: var(--green-500); color: #fff; font-size: 24rpx;
  padding: 10rpx 24rpx; border-radius: 30rpx; line-height: 1; font-weight: 600;
}
.empty-spot { text-align: center; padding: 40rpx 0; display: flex; flex-direction: column; align-items: center; }

.spot-scroll { white-space: nowrap; width: 100%; }
.spot-tag {
  display: inline-flex; flex-direction: column; align-items: flex-start;
  padding: 14rpx 24rpx; margin-right: 12rpx; border-radius: 12rpx;
  background: #F7F8FA; position: relative; min-width: 160rpx;
}
.spot-tag.active { background: var(--green-500); color: #fff; }
.spot-name {
  font-size: 26rpx; font-weight: 600; max-width: 200rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.spot-addr {
  font-size: 20rpx; color: #999; max-width: 200rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; margin-top: 4rpx;
}
.spot-tag.active .spot-addr { color: rgba(255,255,255,0.7); }
.spot-close {
  position: absolute; top: 4rpx; right: 10rpx;
  font-size: 28rpx; opacity: 0.4;
}

/* Weather Card */
.weather-card { margin-top: 20rpx; }
.weather-location { font-size: 24rpx; color: var(--text-secondary); margin-bottom: 12rpx; }
.weather-main { display: flex; align-items: center; gap: 20rpx; }
.weather-icon { font-size: 100rpx; }
.weather-temp { font-size: 90rpx; font-weight: 200; }
.weather-divider { width: 2rpx; height: 80rpx; background: #E5E7EB; }
.weather-desc { font-size: 28rpx; color: #555; display: block; }
.weather-feel { font-size: 22rpx; color: var(--text-secondary); margin-top: 4rpx; }

.weather-metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 24rpx; }
.metric { display: flex; align-items: center; gap: 16rpx; background: #F7F8FA; padding: 20rpx; border-radius: var(--radius-sm); }
.metric-icon { font-size: 36rpx; }
.metric-val { font-size: 36rpx; font-weight: 700; display: block; }
.metric-sm { font-size: 24rpx !important; }
.metric-unit { font-size: 22rpx; color: var(--text-secondary); font-weight: 400; }
.metric-lbl { font-size: 22rpx; color: var(--text-secondary); }

.forecast-row { display: flex; gap: 12rpx; margin-top: 20rpx; }
.fc-item { flex: 1; text-align: center; padding: 16rpx; background: #F7F8FA; border-radius: var(--radius-sm); }
.fc-day { font-size: 22rpx; color: var(--text-secondary); }
.fc-icon { font-size: 40rpx; margin: 8rpx 0; display: block; }
.fc-temp { font-size: 26rpx; font-weight: 600; }

/* Score Card */
.score-card { margin-top: 20rpx; text-align: center; padding: 40rpx 32rpx !important; color: #fff !important; background: #999 !important; }
.score-card.good { background: linear-gradient(135deg, #1AAD5F, #20C96A) !important; }
.score-card.ok { background: linear-gradient(135deg, #FF9A3C, #FFB84D) !important; }
.score-card.bad { background: linear-gradient(135deg, #909399, #B0B3BB) !important; }
.score-label { font-size: 26rpx; opacity: 0.85; }
.score-value { font-size: 100rpx; font-weight: 800; display: block; line-height: 1.2; }
.score-advice { font-size: 24rpx; margin-top: 24rpx; line-height: 2.2; text-align: left; }
.score-advice text { display: block; }

/* Target Fish */
.fish-target-card { margin-top: 20rpx; }
.fish-picker {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22rpx 24rpx; background: #F7F8FA; border-radius: var(--radius-sm);
  margin-top: 12rpx;
}
.picker-text { font-size: 30rpx; font-weight: 600; color: var(--text); }
.picker-arrow { font-size: 22rpx; color: var(--text-secondary); }

.target-result { margin-top: 24rpx; }
.target-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.target-name { font-size: 34rpx; font-weight: 800; }
.target-score { font-size: 26rpx; font-weight: 700; padding: 6rpx 20rpx; border-radius: 20rpx; }
.target-score.hot { background: #E8F8EF; color: #10703D; }
.target-score.ok { background: #FFF8E1; color: #B45309; }
.target-score.cold { background: #F5F5F5; color: #999; }

.target-section { margin-bottom: 16rpx; }
.target-label { font-size: 26rpx; font-weight: 700; display: block; margin-bottom: 8rpx; }
.target-bait { display: flex; gap: 10rpx; flex-wrap: wrap; }
.target-text { font-size: 24rpx; color: #555; line-height: 1.8; }

.target-tips {
  margin-top: 16rpx; padding: 20rpx; background: #E8F8EF;
  border-radius: var(--radius-sm); font-size: 24rpx; color: #10703D; line-height: 1.6;
}
