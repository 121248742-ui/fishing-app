<view class="spot-section card">
  <view class="spot-header">
    <text class="spot-title">📍 我的钓点</text>
    <button class="add-btn" bindtap="addSpot">+ 添加钓点</button>
  </view>

  <view wx:if="{{spots.length === 0}}" class="empty-spot">
    <text style="font-size:40rpx;">🗺️</text>
    <text style="font-size:24rpx;color:#ccc;margin-top:8rpx;">点击"添加钓点"在地图上选择</text>
  </view>

  <scroll-view scroll-x class="spot-scroll" wx:else>
    <view class="spot-tag {{activeSpot && activeSpot.name === item.name ? 'active' : ''}}"
      wx:for="{{spots}}" wx:key="name"
      bindtap="selectSpot" data-idx="{{index}}">
      <text class="spot-name">{{item.name}}</text>
      <text class="spot-addr">{{item.address}}</text>
      <text class="spot-close" bindtap="removeSpot" data-idx="{{index}}">×</text>
    </view>
  </scroll-view>
</view>

<view wx:if="{{activeSpot && weather}}" class="weather-card card">
  <view class="weather-location">{{activeSpot.name}}</view>
  <view class="weather-main">
    <text class="weather-icon">{{weather.icon}}</text>
    <text class="weather-temp">{{weather.temp}}°</text>
    <view class="weather-divider"></view>
    <view>
      <text class="weather-desc">{{weather.desc}}</text>
      <text class="weather-feel">体感 {{weather.temp - 1}}° ~ {{weather.temp + 2}}°</text>
    </view>
  </view>

  <view class="weather-metrics">
    <view class="metric">
      <text class="metric-icon">🌡️</text>
      <view>
        <text class="metric-val">{{weather.pressure}} <text class="metric-unit">hPa</text></text>
        <text class="metric-lbl">气压</text>
      </view>
    </view>
    <view class="metric">
      <text class="metric-icon">💧</text>
      <view>
        <text class="metric-val">{{weather.humidity}}<text class="metric-unit">%</text></text>
        <text class="metric-lbl">湿度</text>
      </view>
    </view>
    <view class="metric">
      <text class="metric-icon">🌬️</text>
      <view>
        <text class="metric-val metric-sm">{{weather.wind}}</text>
        <text class="metric-lbl">风力风向</text>
      </view>
    </view>
    <view class="metric">
      <text class="metric-icon">🌡️</text>
      <view>
        <text class="metric-val">{{forecast[0].hi}}°/<text class="metric-unit">{{forecast[0].lo}}°</text></text>
        <text class="metric-lbl">最高/最低</text>
      </view>
    </view>
  </view>

  <view class="forecast-row">
    <view class="fc-item" wx:for="{{forecast}}" wx:key="day" wx:if="{{index > 0}}">
      <text class="fc-day">{{item.day}}</text>
      <text class="fc-icon">{{item.icon}}</text>
      <text class="fc-temp">{{item.hi}}°/{{item.lo}}°</text>
    </view>
  </view>
</view>

<view wx:elif="{{activeSpot}}" class="card" style="text-align:center;padding:60rpx;">
  <text wx:if="{{loading}}" style="font-size:32rpx;">⏳ 加载天气中...</text>
</view>

<view wx:elif="{{spots.length === 0}}" class="card" style="text-align:center;padding:60rpx;">
  <text style="font-size:40rpx;">☀️</text>
  <view style="font-size:24rpx;color:#ccc;margin-top:12rpx;">添加钓点查看当地天气</view>
</view>

<view wx:if="{{activeSpot && weather}}" class="score-card card {{score >= 80 ? 'good' : (score >= 55 ? 'ok' : 'bad')}}">
  <text class="score-label">今日出钓指数</text>
  <text class="score-value">{{score}}</text>
  <view class="score-advice">
    <text wx:for="{{advice}}" wx:key="*this">{{item}}</text>
  </view>
</view>

<!-- Target Fish Selector -->
<view wx:if="{{activeSpot && weather}}" class="card fish-target-card">
  <view class="section-title">🎯 选择目标鱼</view>
  <picker mode="selector" range="{{fishList}}" value="{{fishIdx}}" bindchange="onFishChange">
    <view class="fish-picker">
      <text class="picker-text">{{fishList[fishIdx] || '选择鱼种'}}</text>
      <text class="picker-arrow">▼</text>
    </view>
  </picker>

  <view wx:if="{{activeFish}}" class="target-result">
    <view class="target-header">
      <text class="target-name">{{activeFish.name}}</text>
      <text class="target-score {{fishScore >= 70 ? 'hot' : (fishScore >= 40 ? 'ok' : 'cold')}}">活跃指数 {{fishScore}}</text>
    </view>

    <view class="target-section">
      <text class="target-label">🪱 推荐饵料</text>
      <view class="target-bait">
        <text class="tag-{{item.tier}}" wx:for="{{activeFish.bait}}" wx:key="name">{{item.name}}</text>
      </view>
    </view>

    <view class="target-section">
      <text class="target-label">🎣 作钓思路</text>
      <text class="target-text">{{activeFish.technique}}</text>
    </view>

    <view class="target-tips">
      <text>💡 {{activeFish.tips}}</text>
    </view>
  </view>
</view>
